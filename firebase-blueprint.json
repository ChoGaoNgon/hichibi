{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories (e.g., Coffee, Tea, Food)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "Coffee House products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "options": {
          "type": "object",
          "properties": {
            "sizes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": "number" }
                }
              }
            },
            "toppings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": "number" }
                }
              }
            }
          }
        },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "size": { "type": "string" },
              "toppings": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "delivering", "completed", "cancelled"] },
        "deliveryMethod": { "type": "string", "enum": ["delivery", "pickup", "dine-in"] },
        "address": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "deliveryMethod"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Discount vouchers",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "maxUsage": { "type": "number" },
        "usedCount": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "discountValue", "maxUsage", "usedCount", "startDate", "endDate", "isActive"]
    },
    "QuickNote": {
      "title": "Quick Note",
      "description": "Pre-defined notes for order items",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Menu products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/vouchers/{voucherId}": {
      "schema": "Voucher",
      "description": "Discount vouchers"
    },
    "/quick_notes/{noteId}": {
      "schema": "QuickNote",
      "description": "Pre-defined order item notes"
    },
    "/settings/{settingId}": {
      "schema": "object",
      "description": "Store settings and configuration"
    }
  }
}

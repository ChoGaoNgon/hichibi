rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, createdAt
    //
    // Collection: categories
    // Fields: name, slug, order
    //
    // Collection: products
    // Fields: name, description, price, image, category, options, isAvailable
    //
    // Collection: orders
    // Fields: userId, customerName, customerPhone, items, totalAmount, status, deliveryMethod, address, createdAt, updatedAt
    //
    // Collection: vouchers
    // Fields: code, discountType, discountValue, minOrderAmount, maxUsage, usedCount, startDate, endDate, isActive, createdAt, updatedAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dang.nh.aprotrain@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'] ||
          (request.auth.token.email == "dang.nh.aprotrain@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'staff', 'customer'];
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0 &&
             (!('image' in data) || (data.image is string && data.image.size() < 1000));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             (!('shopNotes' in data) || (data.shopNotes is string && data.shopNotes.size() < 1000));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'deliveryMethod', 'customerName', 'customerPhone']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'delivering', 'completed', 'cancelled'] &&
             data.deliveryMethod in ['delivery', 'pickup', 'dine-in'] &&
             data.customerName is string &&
             data.customerPhone is string;
    }

    function isValidVoucher(data) {
      return data.keys().hasAll(['code', 'discountType', 'discountValue', 'maxUsage', 'startDate', 'endDate', 'isActive']) &&
             data.code is string && data.code.size() == 6 &&
             data.discountType in ['percentage', 'fixed'] &&
             data.discountValue is number && data.discountValue > 0 &&
             data.maxUsage is number && data.maxUsage > 0 &&
             data.startDate is timestamp &&
             data.endDate is timestamp &&
             data.isActive is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'customer' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin()) && isValidUser(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isStaff() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isValidOrder(request.resource.data) && 
                      (request.resource.data.userId == 'guest' || (isAuthenticated() && request.resource.data.userId == request.auth.uid));
      allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled' && resource.data.status == 'pending');
    }

    match /vouchers/{voucherId} {
      allow read: if true;
      allow create: if isStaff() && isValidVoucher(request.resource.data);
      allow update: if (isStaff() && isValidVoucher(request.resource.data)) || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']) && request.resource.data.usedCount == resource.data.usedCount + 1);
      allow delete: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
